# Cloudflare R2 Configuration
# Obtenha essas credenciais no Cloudflare Dashboard > R2

# Account ID (encontrado na URL do dashboard ou nas configurações do R2)
R2_ACCOUNT_ID=your_account_id_here

# API Token credentials (criado em R2 > Manage R2 API Tokens)
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# Nome do bucket criado no R2
R2_BUCKET_NAME=eixoglobal-erp-storage

# URL pública (OPCIONAL - apenas se você configurou um domínio customizado)
# Exemplo: https://cdn.eixoglobal.com
# Se não configurado, será usado o endpoint padrão do R2
R2_PUBLIC_URL=

# Instruções:
# 1. Copie este arquivo para .env.local
# 2. Preencha os valores com suas credenciais do Cloudflare R2
# 3. Nunca commite o arquivo .env.local no Git

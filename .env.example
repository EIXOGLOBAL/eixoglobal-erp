# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://eixo:eixo2026@localhost:5432/eixo_erp"

# ==========================================
# AUTH
# ==========================================
SESSION_SECRET="generate-with-openssl-rand-base64-64"

# ==========================================
# IA — Provedores (em ordem de prioridade/fallback)
# ==========================================
# Provider primario: google | groq | openrouter
AI_PRIMARY_PROVIDER=google

# Google Gemini (primario)
GOOGLE_GENERATIVE_AI_API_KEY=""

# Groq (fallback 1)
GROQ_API_KEY=""

# OpenRouter (fallback 2 — suporta modelos gratuitos)
OPENROUTER_API_KEY=""

# Anthropic (legado — ainda suportado via sistema de settings)
ANTHROPIC_API_KEY=""

# ==========================================
# D4SIGN (Assinatura Digital)
# ==========================================
D4SIGN_TOKEN_API=""
D4SIGN_CRYPT_KEY=""
D4SIGN_SAFE_UUID=""
D4SIGN_WEBHOOK_SECRET=""
D4SIGN_BASE_URL="https://secure.d4sign.com.br/api/v1"

# ==========================================
# APP
# ==========================================
NEXT_PUBLIC_APP_URL="https://erp.eixoglobal.com.br"
NEXT_PUBLIC_APP_NAME="Eixo Global ERP"
NODE_ENV="development"

# ==========================================
# UPLOAD
# ==========================================
UPLOAD_MAX_SIZE=10485760

# ==========================================
# SEFAZ (NFe/NFS-e Integration)
# ==========================================
# SEFAZ API endpoint for NFS-e emission
SEFAZ_URL="https://nfse.prefeitura.sp.gov.br/ws/lotenfe.asmx"
# Path to SEFAZ digital certificate (PFX/P12 format)
# Leave empty for development mode (simulated emissions)
SEFAZ_CERTIFICATE_PATH=""

# ==========================================
# WEATHER SERVICE
# ==========================================
# OpenWeather API key for current weather and detailed forecasts
# Get at: https://openweathermap.org/api
# If not provided, system will fall back to free Open-Meteo API
OPENWEATHER_API_KEY=""

# ==========================================
# WHATSAPP — Evolution API
# ==========================================
# URL base da Evolution API (sem trailing slash)
EVOLUTION_API_URL=""
# API Key configurada na instancia Evolution
EVOLUTION_API_KEY=""
# Nome da instancia Evolution (ex: "eixo-erp")
EVOLUTION_INSTANCE=""

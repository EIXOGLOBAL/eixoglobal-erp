// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../src/lib/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------
// CORE: Auth & Tenants
// --------------------------------------------------------

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String   // Hashed password
  role      Role     @default(USER)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Permissões granulares (configuráveis pelo ADMIN)
  canDelete          Boolean  @default(false)  // Pode excluir registros
  canApprove         Boolean  @default(false)  // Pode aprovar boletins, contratos
  canManageFinancial Boolean  @default(false)  // Acesso ao módulo financeiro
  canManageHR        Boolean  @default(false)  // Acesso a folha, salários
  canManageSystem    Boolean  @default(false)  // Acesso a Sistema (empresas, usuários)
  canViewReports     Boolean  @default(true)   // Pode ver relatórios

  projects  Project[]
  registeredMeasurements Measurement[] @relation("MeasurementRegistrar")
  approvedMeasurements   Measurement[] @relation("MeasurementApprover")
  inventoryMovements InventoryMovement[]
  
  // Bulletin relations
  createdBulletins  MeasurementBulletin[] @relation("BulletinCreator")
  engineerBulletins MeasurementBulletin[] @relation("BulletinEngineer")
  managerBulletins  MeasurementBulletin[] @relation("BulletinManager")
  uploadedAttachments BulletinAttachment[] @relation("AttachmentUploader")
  bulletinComments BulletinComment[] @relation("CommentAuthor")
  
  userDepartments     UserDepartment[]
  workTasksCreated    WorkTask[]           @relation("WorkTaskCreator")
  workTaskAssignments WorkTaskAssignment[] @relation("WorkTaskAssignee")
  workTaskComments    WorkTaskComment[]    @relation("WorkTaskCommentAuthor")
  workTaskActivities  WorkTaskActivity[]   @relation("WorkTaskActivityAuthor")
  notifications       Notification[]
  announcements       Announcement[]       @relation("AnnouncementAuthor")
  acceptedTermsAt     DateTime?
  auditLogs       AuditLog[] @relation("AuditLogUser")
  supplierEvaluations SupplierEvaluation[] @relation("SupplierEvaluator")

  @@map("users")
}

model Company {
  id         String   @id @default(uuid())
  code       String?  // Código sequencial
  name       String   // Razão Social / Nome Empresarial
  tradeName  String?  // Nome Fantasia
  cnpj       String   @unique
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  zipCode    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  contacts   CompanyContact[]
  users      User[]
  projects  Project[]
  employees Employee[]
  contractors Contractor[]
  contracts Contract[]
  bankAccounts BankAccount[]
  fiscalNotes FiscalNote[]
  financialRecords FinancialRecord[]
  materials Material[]
  costCompositions CostComposition[]
  suppliers Supplier[]
  costCenters CostCenter[]
  trainings Training[]
  purchaseOrders  PurchaseOrder[]
  dailyReports    DailyReport[]
  equipment       Equipment[]

  departments    Department[]
  workTasks      WorkTask[]
  workTaskLabels WorkTaskLabel[]
  notifications  Notification[]
  announcements  Announcement[]
  auditLogs      AuditLog[]
  salaryTables   SalaryTable[]
  rentalItems    RentalItem[]
  rentals        Rental[]
  clients        Client[]
  budgets        Budget[]
  bankStatements BankStatement[]
  workCalendars  WorkCalendar[]
  bdiConfigs     BDIConfig[]

  @@map("companies")
}


model CompanyContact {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String   // EMAIL, PHONE
  value       String
  department  String?
  responsible String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("company_contacts")
}

// --------------------------------------------------------
// MODULE 1: Measurements & Workforce (Core)
// --------------------------------------------------------

model Employee {
  id          String   @id @default(uuid())
  matricula   String?  // Código sequencial editável pelo usuário
  name        String
  jobTitle    String   // Cargo
  document    String?  // CPF
  status      EmployeeStatus @default(ACTIVE)
  skills      String   @db.Text // JSON string of skills for SQLite
  costPerHour Decimal? @db.Decimal(18, 4)
  avatarUrl   String?

  managerId   String?
  manager     Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  reports     Employee[] @relation("EmployeeManager")
  department  String?

  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Grade Salarial
  salaryGradeId String?
  salaryGrade   SalaryGrade? @relation("EmployeeSalaryGrade", fields: [salaryGradeId], references: [id])

  // Datas contratuais
  admissionDate   DateTime?
  leaveDate       DateTime?
  terminationDate DateTime?

  // Salário
  monthlySalary   Decimal?  @db.Decimal(18, 4)
  hoursPerMonth   Int       @default(220)
  overtimeRates   String    @default("[]") @db.Text // JSON: [50, 70, 100] (percentuais extras além do padrão)

  // Alojamento
  housed          Boolean   @default(false)

  // Benefícios fixos
  valeTransporte  Boolean   @default(false)
  vtDailyValue    Decimal?  @db.Decimal(18, 4)
  valeAlimentacao Decimal?  @db.Decimal(18, 4)
  planoSaude      Decimal?  @db.Decimal(18, 4)
  outrosBeneficios Decimal? @db.Decimal(18, 4)

  // Benefícios variáveis (produção, gratificação, ajuda de custo, etc.)
  variableBenefits EmployeeBenefit[]

  allocations Allocation[]
  measurements Measurement[] // Track productivity
  trainingParticipations TrainingParticipant[]
  vacationRequests VacationRequest[]
  salaryHistory SalaryHistory[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("employees")
}

model EmployeeBenefit {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name        String   // "Produção", "Gratificação", "Ajuda de Custo", etc.
  type        String   @default("OUTRO") // PRODUCAO, GRATIFICACAO, AJUDA_CUSTO, DIARIA, OUTRO
  value       Decimal  @db.Decimal(18, 4)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("employee_benefits")
}

// Empreiteiros / Terceirizados (Pessoas Jurídicas ou Físicas externas)
model Contractor {
  id          String   @id @default(uuid())
  code        String?  // Código sequencial
  name        String
  document    String?  // CNPJ/CPF
  type        ContractorType @default(COMPANY)
  status      ContractorStatus @default(ACTIVE)

  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  contracts   Contract[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("contractors")
}

model Project {
  id          String   @id @default(uuid())
  code        String?  // Código sequencial
  name        String
  description String?  @db.Text
  location    String?
  address     String?  @db.Text
  latitude    Float?
  longitude   Float?
  startDate   DateTime
  endDate     DateTime?
  budget      Decimal?
  area        Float?   // área em m²
  status      ProjectStatus @default(PLANNING)

  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  engineerId  String?
  engineer    User?   @relation(fields: [engineerId], references: [id])

  clientId    String?
  client      Client? @relation(fields: [clientId], references: [id])

  contracts   Contract[]
  allocations Allocation[]
  measurements Measurement[]
  bulletins   MeasurementBulletin[]
  compositions CostComposition[]
  inventoryMovements InventoryMovement[]
  tasks       ProjectTask[]
  purchaseOrders  PurchaseOrder[]
  dailyReports    DailyReport[]
  equipmentUsages EquipmentUsage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workTasks      WorkTask[]
  statusHistory  ProjectStatusHistory[]
  rentals        Rental[]
  costCenters    CostCenter[]
  financialRecords FinancialRecord[] @relation("FinancialRecordProject")
  rentalPayments   RentalPayment[]   @relation("RentalPaymentProject")
  fiscalNotes      FiscalNote[]      @relation("FiscalNoteProject")
  budgets          Budget[]
  baselineStartDate  DateTime?
  baselineEndDate    DateTime?
  polygonCoordinates String?
  city               String?
  state              String?
  workCalendars      WorkCalendar[]

  @@map("projects")
}


model Contract {
  id          String   @id @default(uuid())
  identifier  String   // e.g. "CTR-2026/001"
  description String?  @db.Text
  value       Decimal? @db.Decimal(18, 4) 
  startDate   DateTime
  endDate     DateTime?
  status      ContractStatus @default(ACTIVE)
  
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Can be a contract with a Contractor (External) or Internal management
  contractorId String?
  contractor   Contractor? @relation(fields: [contractorId], references: [id])

  items       ContractItem[]
  amendments  ContractAmendment[]
  adjustments ContractAdjustment[]
  bulletins   MeasurementBulletin[]

  // D4Sign - Assinatura Digital
  d4signDocumentUuid   String?
  d4signStatus         String?   // DRAFT|PROCESSING|SIGNED|CANCELED
  d4signSentAt         DateTime?
  d4signSignedAt       DateTime?
  d4signSignedFileUrl  String?
  signatureRequired    Boolean   @default(false)

  contractNumber    String?
  contractType      ContractType?
  modalidade        String?
  object            String?  @db.Text
  warrantyValue     Decimal? @db.Decimal(18, 4)
  warrantyExpiry    DateTime?
  executionDeadline Int?
  baselineEndDate   DateTime?
  reajusteIndex     ReajusteIndex?
  reajusteBaseDate  DateTime?
  fiscalName        String?
  witnessNames      String?  @db.Text
  paymentTerms      String?  @db.Text
  retentionPercent  Decimal? @db.Decimal(5, 2)
  schedule          FinancialScheduleItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("contracts")
}

model ContractItem {
  id          String   @id @default(uuid())
  description String   @db.Text
  unit        String   // e.g. "m2", "sc", "h"
  quantity    Decimal  @db.Decimal(18, 4)
  unitPrice   Decimal  @db.Decimal(18, 4)  
  
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  measurements Measurement[]
  bulletinItems MeasurementBulletinItem[]
  
  @@map("contract_items")
}

model Allocation {
  id          String   @id @default(uuid())
  startDate   DateTime
  endDate     DateTime?
  
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("allocations")
}

model Measurement {
  id          String   @id @default(uuid())
  date        DateTime
  quantity    Decimal  @db.Decimal(18, 4)
  description String?  @db.Text
  status      MeasurementStatus @default(DRAFT)
  rejectionReason String? @db.Text
  
  // Who performed the work (Internal Employee)
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  
  // Who registered/approved (System User)
  registeredById String
  registeredBy   User @relation("MeasurementRegistrar", fields: [registeredById], references: [id])

  // Approver
  approvedById String?
  approvedBy   User? @relation("MeasurementApprover", fields: [approvedById], references: [id])

  contractItemId String
  contractItem   ContractItem @relation(fields: [contractItemId], references: [id], onDelete: Cascade)
  
  // Direct link to project for faster queries
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Many-to-Many relation with Fiscal Notes (One measurement can be in multiple notes, or many notes for one ?)
  // Usually Many Measurements -> One Fiscal Note
  fiscalNoteId String?
  fiscalNote   FiscalNote? @relation(fields: [fiscalNoteId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("measurements")
}


// --------------------------------------------------------
// MODULE 2: Financial & Fiscal
// --------------------------------------------------------

model BankAccount {
  id          String   @id @default(uuid())
  name        String   // e.g. "Itaú Master"
  bankName    String
  accountNumber String
  agency      String
  balance     Decimal  @default(0) @db.Decimal(18, 4) 
  currency    String   @default("BRL")
  
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  transactions FinancialRecord[]
  statements   BankStatement[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bank_accounts")
}

model FinancialRecord {
  id          String   @id @default(uuid())
  description String   @db.Text
  amount      Decimal  @db.Decimal(18, 4)
  type        TransactionType // INCOME, EXPENSE
  status      TransactionStatus @default(PENDING)
  dueDate     DateTime
  paidDate    DateTime?
  paidAmount  Decimal  @default(0) @db.Decimal(18, 4)

  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])

  fiscalNoteId  String? @unique
  fiscalNote    FiscalNote? @relation(fields: [fiscalNoteId], references: [id])

  category    String? // Could be a relation to a Category model

  projectId    String?
  project      Project?    @relation("FinancialRecordProject", fields: [projectId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation("FinancialRecordCostCenter", fields: [costCenterId], references: [id])

  bankStatementTransaction BankStatementTransaction?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("financial_records")
}

// --------------------------------------------------------
// MODULE: Suppliers / Fornecedores
// --------------------------------------------------------

model Supplier {
  id          String   @id @default(uuid())
  name        String
  tradeName   String?  // Nome Fantasia
  cnpj        String?  // CNPJ ou CPF
  email       String?
  phone       String?
  address     String?  @db.Text
  city        String?
  state       String?
  zipCode     String?
  category    SupplierCategory @default(OTHER)
  isActive    Boolean  @default(true)
  notes       String?  @db.Text

  // Campos avançados de gestão
  rating           Decimal?         @db.Decimal(3, 2)
  paymentTermDays  Int?
  observations     String?          @db.Text
  website          String?

  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fiscalNotes FiscalNote[]
  purchaseOrders  PurchaseOrder[]
  contacts    SupplierContact[]
  documents   SupplierDocument[]
  evaluations SupplierEvaluation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("suppliers")
}

model FiscalNote {
  id          String   @id @default(uuid())
  number      String
  series      String?
  type        DocumentType // Expanded: NFE, NFSE, CTE, FATURA, RECIBO, CONTA_ENERGIA, CONTA_AGUA, CONTA_TELEFONE, CONTA_INTERNET, ALUGUEL, OUTRO
  description String?  @db.Text // Descrição livre do documento
  xmlContent  String?  @db.Text // Full XML storage (NF-e)
  accessKey   String?  // Chave de Acesso (NF-e/CT-e)
  issuedDate  DateTime
  dueDate     DateTime? // Vencimento (faturas, contas)
  value       Decimal  @db.Decimal(18, 4)
  status      FiscalNoteStatus @default(ISSUED)

  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  financialRecord FinancialRecord? // Back reference

  measurements Measurement[]

  projectId    String?
  project      Project?    @relation("FiscalNoteProject", fields: [projectId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation("FiscalNoteCostCenter", fields: [costCenterId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("fiscal_notes")
}

// --------------------------------------------------------
// PROFESSIONAL MODELS: Contracts Management
// --------------------------------------------------------

model ContractAmendment {
  id            String   @id @default(uuid())
  number        String   // "TA-001", "TA-002"
  description   String   @db.Text
  type          String   // VALUE_CHANGE, DEADLINE_CHANGE, SCOPE_CHANGE, MIXED
  oldValue      Decimal? @db.Decimal(18, 4)
  newValue      Decimal? @db.Decimal(18, 4)
  oldEndDate    DateTime?
  newEndDate    DateTime?
  justification String   @db.Text
  approvedAt    DateTime?
  amendmentType AmendmentType?
  approvedBy    String?
  documentRef   String?
  impactAnalysis String? @db.Text

  contractId    String
  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("contract_amendments")
}

model ContractAdjustment {
  id             String   @id @default(uuid())
  indexType      String   // "INCC", "IPCA", "IGP-M"
  baseDate       DateTime
  adjustmentDate DateTime
  oldIndex       Decimal  @db.Decimal(10, 6)
  newIndex       Decimal  @db.Decimal(10, 6)
  percentage     Decimal  @db.Decimal(10, 6)
  baseValue      Decimal? @db.Decimal(18, 4)
  adjustedValue  Decimal? @db.Decimal(18, 4)
  calculationMemoria String? @db.Text

  contractId     String
  contract       Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("contract_adjustments")
}

// --------------------------------------------------------
// PROFESSIONAL MODELS: Measurement Bulletins (Boletins de Medição)
// --------------------------------------------------------

model MeasurementBulletin {
  id                     String   @id @default(uuid())
  number                 String   // "BM-001/2026"
  referenceMonth         String   // "01/2026"
  periodStart            DateTime
  periodEnd              DateTime
  totalValue             Decimal  @default(0) @db.Decimal(18, 4)
  status                 String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED, BILLED
  
  // Workflow timestamps
  submittedAt            DateTime?
  approvedByEngineerAt   DateTime?
  approvedByManagerAt    DateTime?
  approvedByClientAt     DateTime?
  rejectedAt             DateTime?
  rejectionReason        String?  @db.Text
  billedAt               DateTime?
  
  // Relations
  projectId              String
  project                Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  contractId             String
  contract               Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  createdById            String
  createdBy              User @relation("BulletinCreator", fields: [createdById], references: [id])
  
  engineerId             String?
  engineer               User? @relation("BulletinEngineer", fields: [engineerId], references: [id])
  
  managerId              String?
  manager                User? @relation("BulletinManager", fields: [managerId], references: [id])
  
  items                  MeasurementBulletinItem[]
  attachments            BulletinAttachment[]
  comments               BulletinComment[]

  // D4Sign - Assinatura Digital
  d4signDocumentUuid   String?
  d4signStatus         String?
  d4signSentAt         DateTime?
  d4signSignedAt       DateTime?
  d4signSignedFileUrl  String?
  signatureRequired    Boolean   @default(false)

  bulletinNumber    String?
  weatherConditions String?  @db.Text
  workingDays       Int?
  totalDirectCost   Decimal? @db.Decimal(18, 4)
  retentionAmount   Decimal? @db.Decimal(18, 4)
  netAmount         Decimal? @db.Decimal(18, 4)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("measurement_bulletins")
}

model MeasurementBulletinItem {
  id                     String   @id @default(uuid())

  // Item details
  itemCode               String?
  description            String   @db.Text
  unit                   String
  unitPrice              Decimal  @db.Decimal(18, 4)

  // Quantities
  contractedQuantity     Decimal  @db.Decimal(18, 4) // Total contratado
  previousMeasured       Decimal  @default(0) @db.Decimal(18, 4) // Medido anteriormente
  currentMeasured        Decimal  @db.Decimal(18, 4) // Medindo agora
  accumulatedMeasured    Decimal  @db.Decimal(18, 4) // Total acumulado
  balanceQuantity        Decimal  @db.Decimal(18, 4) // Saldo restante

  // Values
  currentValue           Decimal  @db.Decimal(18, 4) // Valor desta medição
  accumulatedValue       Decimal  @db.Decimal(18, 4) // Valor acumulado

  // Progress
  percentageExecuted     Decimal  @db.Decimal(5, 2) // % executado
  accumulatedPercent     Decimal  @default(0) @db.Decimal(5, 2)
  currentPercent         Decimal  @default(0) @db.Decimal(5, 2)
  totalPercent           Decimal  @default(0) @db.Decimal(5, 2)
  memoriaCalculo         String?  @db.Text

  // Relations
  bulletinId             String
  bulletin               MeasurementBulletin @relation(fields: [bulletinId], references: [id], onDelete: Cascade)
  
  contractItemId         String
  contractItem           ContractItem @relation(fields: [contractItemId], references: [id])
  
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  
  @@map("measurement_bulletin_items")
}

model BulletinAttachment {
  id                String   @id @default(uuid())
  fileName          String
  fileType          String
  fileSize          Int
  fileUrl           String
  description       String?
  
  bulletinId        String
  bulletin          MeasurementBulletin @relation(fields: [bulletinId], references: [id], onDelete: Cascade)
  
  uploadedById      String
  uploadedBy        User @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  
  createdAt         DateTime @default(now())
  
  @@map("bulletin_attachments")
}

model BulletinComment {
  id          String   @id @default(uuid())
  text        String   @db.Text
  commentType String   // APPROVAL, REJECTION, OBSERVATION, QUESTION
  isInternal  Boolean  @default(false)
  
  bulletinId  String
  bulletin    MeasurementBulletin @relation(fields: [bulletinId], references: [id], onDelete: Cascade)
  
  authorId    String
  author      User @relation("CommentAuthor", fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
  
  @@map("bulletin_comments")
}

// --------------------------------------------------------
// PROFESSIONAL MODELS: Cost Compositions
// --------------------------------------------------------

model CostComposition {
  id              String   @id @default(uuid())
  code            String   // "COMP-001"
  description     String   @db.Text
  unit            String
  directCost      Decimal  @default(0) @db.Decimal(18, 4)
  bdi             Decimal  @default(0) @db.Decimal(5, 2) // % BDI
  salePrice       Decimal  @default(0) @db.Decimal(18, 4)

  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  materials       CompositionMaterial[]
  labor           CompositionLabor[]
  equipment       CompositionEquipment[]
  versions        CompositionVersion[]

  version          Int               @default(1)
  isTemplate       Boolean           @default(false)
  templateId       String?
  referenceDate    DateTime?
  referenceSource  String?
  compositionStatus CompositionStatus @default(DRAFT)
  notes            String?  @db.Text
  tags             String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("cost_compositions")
}

model CompositionMaterial {
  id              String   @id @default(uuid())
  description     String   @db.Text
  unit            String
  coefficient     Decimal  @db.Decimal(18, 4) // Quantity per unit
  unitCost        Decimal  @db.Decimal(18, 4)
  totalCost       Decimal  @db.Decimal(18, 4)
  wasteFactor     Decimal  @default(0) @db.Decimal(5, 2)
  referenceDate   DateTime?
  supplier        String?

  compositionId   String
  composition     CostComposition @relation(fields: [compositionId], references: [id], onDelete: Cascade)

  @@map("composition_materials")
}

model CompositionLabor {
  id              String   @id @default(uuid())
  description     String   @db.Text
  hours           Decimal  @db.Decimal(10, 2)
  hourlyRate      Decimal  @db.Decimal(18, 4)
  totalCost       Decimal  @db.Decimal(18, 4)
  category        String?
  encargos        Decimal  @default(0) @db.Decimal(5, 2)

  compositionId   String
  composition     CostComposition @relation(fields: [compositionId], references: [id], onDelete: Cascade)

  @@map("composition_labor")
}

model CompositionEquipment {
  id              String   @id @default(uuid())
  description     String   @db.Text
  unit            String
  coefficient     Decimal  @db.Decimal(18, 4)
  unitCost        Decimal  @db.Decimal(18, 4)
  totalCost       Decimal  @db.Decimal(18, 4)
  operatorIncluded Boolean  @default(false)
  fuelCost        Decimal? @db.Decimal(18, 4)
  maintenanceCost Decimal? @db.Decimal(18, 4)

  compositionId   String
  composition     CostComposition @relation(fields: [compositionId], references: [id], onDelete: Cascade)

  @@map("composition_equipment")
}

// --------------------------------------------------------
// MODULE 4: Inventory / Estoque
// --------------------------------------------------------

model Material {
  id           String           @id @default(uuid())
  code         String
  name         String
  description  String?          @db.Text
  unit         String           // e.g. "sc", "m3", "un", "kg"
  category     MaterialCategory @default(OTHER)
  minStock     Decimal          @default(0) @db.Decimal(18, 4)
  currentStock Decimal          @default(0) @db.Decimal(18, 4)
  unitCost     Decimal          @default(0) @db.Decimal(18, 4)
  supplier     String?
  isActive     Boolean          @default(true)

  companyId    String
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  movements    InventoryMovement[]
  purchaseOrderItems PurchaseOrderItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([code, companyId])
  @@map("materials")
}

model InventoryMovement {
  id             String        @id @default(uuid())
  type           MovementType
  quantity       Decimal       @db.Decimal(18, 4)
  unitCost       Decimal?      @db.Decimal(18, 4)
  documentNumber String?
  notes          String?       @db.Text

  materialId     String
  material       Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id])

  userId         String
  user           User @relation(fields: [userId], references: [id])

  createdAt      DateTime @default(now())

  @@map("inventory_movements")
}

// --------------------------------------------------------
// MODULE: Tabela Salarial
// --------------------------------------------------------

model SalaryTable {
  id            String        @id @default(uuid())
  name          String
  description   String?       @db.Text
  isActive      Boolean       @default(true)
  effectiveDate DateTime      @default(now())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  grades        SalaryGrade[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  @@map("salary_tables")
}

model SalaryGrade {
  id            String      @id @default(uuid())
  jobTitle      String
  level         String?
  baseSalary    Decimal     @db.Decimal(18, 4)
  costPerHour   Decimal     @db.Decimal(18, 4)
  hoursPerMonth Int         @default(220)
  benefits      Decimal     @default(0) @db.Decimal(18, 4)
  taxRate       Decimal     @default(0) @db.Decimal(5, 2)
  tableId       String
  table         SalaryTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  employees     Employee[]  @relation("EmployeeSalaryGrade")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  @@unique([tableId, jobTitle, level])
  @@map("salary_grades")
}

// --------------------------------------------------------
// MODULE: Clients / Clientes
// --------------------------------------------------------

model Client {
  id           String       @id @default(uuid())
  code         String?

  type         ClientType   @default(COMPANY)

  // Pessoa Jurídica
  companyName  String?
  tradeName    String?
  cnpj         String?

  // Pessoa Física
  personName   String?
  cpf          String?

  // Nome para exibição
  displayName  String

  // Contato
  email        String?
  phone        String?
  mobile       String?

  // Endereço
  address      String?  @db.Text
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?

  // Responsável
  contactPerson String?
  contactRole   String?

  notes        String?  @db.Text
  status       ClientStatus @default(ACTIVE)

  companyId    String
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  projects     Project[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("clients")
}


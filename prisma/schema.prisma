enum SupplierDocumentType {
  CONTRATO_SOCIAL
  CARTAO_CNPJ
  CERTIDAO_NEGATIVA
  CERTIDAO_FGTS
  CERTIDAO_TRABALHISTA
  APOLICE_SEGURO
  ALVARA
  OUTROS
}

model SupplierContact {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name       String
  role       String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("supplier_contacts")
}

model SupplierDocument {
  id          String               @id @default(uuid())
  supplierId  String
  supplier    Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type        SupplierDocumentType
  filename    String
  filePath    String
  expiresAt   DateTime?
  uploadedAt  DateTime             @default(now())
  uploadedBy  String

  @@map("supplier_documents")
}

model SupplierEvaluation {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  evaluatedBy String
  evaluator   User     @relation("SupplierEvaluator", fields: [evaluatedBy], references: [id])
  score       Decimal  @db.Decimal(3, 2) // 1 a 5 (média geral)
  quality     Decimal  @db.Decimal(3, 2) // 1 a 5
  delivery    Decimal  @db.Decimal(3, 2) // 1 a 5
  price       Decimal  @db.Decimal(3, 2) // 1 a 5
  support     Decimal  @db.Decimal(3, 2) // 1 a 5
  comment     String?  @db.Text
  createdAt   DateTime @default(now())

  @@map("supplier_evaluations")
}

// ============================================================
// MODULE: Orçamento por Centro de Custo (Cost Center Budget)
// ============================================================

model CostCenterBudget {
  id            String     @id @default(uuid())
  costCenterId  String
  costCenter    CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  year          Int
  month         Int?       // null = orçamento anual
  budgetedAmount Decimal   @db.Decimal(18, 4)
  notes         String?    @db.Text
  createdBy     String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([costCenterId, year, month])
  @@map("cost_center_budgets")
}


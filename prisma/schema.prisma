  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation("SafetyInspections", fields: [projectId], references: [id])
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  date            DateTime
  inspectorId     String
  inspector       User     @relation("SafetyInspector", fields: [inspectorId], references: [id])
  type            String
  checklist       Json?
  overallScore    Float?
  findings        String?
  recommendations String?
  status          String   @default("DRAFT")
  photos          String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId, date])
  @@index([companyId])
  @@map("safety_inspections")
}

model ApprovalWorkflow {
  id          String          @id @default(cuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id])
  name        String
  description String?
  entityType  String
  levels      ApprovalLevel[]
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([companyId, entityType])
  @@map("approval_workflows")
}

model ApprovalLevel {
  id             String           @id @default(cuid())
  workflowId     String
  workflow       ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  level          Int
  roleRequired   Role?
  specificUserId String?
  specificUser   User?            @relation("ApprovalLevelUser", fields: [specificUserId], references: [id])
  minAmount      Float?
  maxAmount      Float?
  createdAt      DateTime         @default(now())

  @@index([workflowId, level])
  @@map("approval_levels")
}

model ApprovalRequest {
  id            String                @id @default(cuid())
  companyId     String
  company       Company               @relation(fields: [companyId], references: [id])
  entityType    String
  entityId      String
  currentLevel  Int                   @default(1)
  status        ApprovalRequestStatus @default(PENDING)
  requestedById String
  requestedBy   User                  @relation("ApprovalRequester", fields: [requestedById], references: [id])
  history       ApprovalHistory[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([companyId, entityType, status])
  @@index([entityType, entityId])
  @@map("approval_requests")
}

enum ApprovalRequestStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

model ApprovalHistory {
  id        String          @id @default(cuid())
  requestId String
  request   ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  level     Int
  action    String
  userId    String
  user      User            @relation("ApprovalActor", fields: [userId], references: [id])
  comments  String?
  createdAt DateTime        @default(now())

  @@index([requestId])
  @@map("approval_histories")
}

model DocumentFolder {
  id        String           @id @default(cuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  projectId String?
  project   Project?         @relation("DocumentFolders", fields: [projectId], references: [id])
  name      String
  parentId  String?
  parent    DocumentFolder?  @relation("SubFolders", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("SubFolders")
  documents DocumentFile[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([companyId, projectId])
  @@index([parentId])
  @@map("document_folders")
}

model DocumentFile {
  id           String               @id @default(cuid())
  companyId    String
  company      Company              @relation(fields: [companyId], references: [id])
  folderId     String?
  folder       DocumentFolder?      @relation(fields: [folderId], references: [id])
  name         String
  description  String?
  category     DocumentFileCategory @default(OTHER)
  filePath     String
  fileSize     Int
  mimeType     String
  version      Int                  @default(1)
  uploadedById String
  uploadedBy   User                 @relation("DocumentUploader", fields: [uploadedById], references: [id])
  status       String               @default("DRAFT")
  tags         String[]
  versions     DocumentVersion[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([companyId, category])
  @@index([folderId])
  @@map("document_files")
}

enum DocumentFileCategory {
  DRAWING
  SPECIFICATION
  MEMORIAL
  ART_RRT
  PERMIT
  CONTRACT
  REPORT
  PHOTO
  INVOICE
  CERTIFICATE
  MANUAL
  OTHER
}

model DocumentVersion {
  id           String       @id @default(cuid())
  documentId   String
  document     DocumentFile @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version      Int
  filePath     String
  fileSize     Int
  uploadedById String
  uploadedBy   User         @relation("VersionUploader", fields: [uploadedById], references: [id])
  changeNotes  String?
  createdAt    DateTime     @default(now())

  @@index([documentId, version])
  @@map("document_versions")
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation("ProgressPhotos", fields: [projectId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  filePath  String
  thumbnail String?
  caption   String?
  category  String?
  latitude  Float?
  longitude Float?
  takenById String
  takenBy   User     @relation("PhotoTaker", fields: [takenById], references: [id])
  takenAt   DateTime
  tags      String[]
  createdAt DateTime @default(now())

  @@index([projectId, takenAt])
  @@index([companyId])
  @@map("progress_photos")
}

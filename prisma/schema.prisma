// --------------------------------------------------------
// MODULE: Centro de Custo (Cost Centers)
// --------------------------------------------------------

model CostCenter {
  id          String   @id @default(uuid())
  code        String
  name        String
  description String?
  type        CostCenterType @default(OPERATIONAL)
  isActive    Boolean  @default(true)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  parentId    String?
  parent      CostCenter?  @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children    CostCenter[] @relation("CostCenterHierarchy")
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Reverse relations from cost models
  financialRecords FinancialRecord[] @relation("FinancialRecordCostCenter")
  equipmentUsages  EquipmentUsage[]  @relation("EquipmentUsageCostCenter")
  rentals          Rental[]          @relation("RentalCostCenter")
  rentalPayments   RentalPayment[]   @relation("RentalPaymentCostCenter")
  purchaseOrders   PurchaseOrder[]   @relation("PurchaseOrderCostCenter")
  fiscalNotes      FiscalNote[]      @relation("FiscalNoteCostCenter")
  budgets          CostCenterBudget[]

  @@unique([code, companyId])
  @@map("cost_centers")
}

enum CostCenterType {
  OPERATIONAL    // Operacional (produção, obras)
  ADMINISTRATIVE // Administrativo
  FINANCIAL      // Financeiro
  COMMERCIAL     // Comercial/Vendas
  OTHER
}

// --------------------------------------------------------
// MODULE: Cronograma de Obra (Project Schedule)
// --------------------------------------------------------

model ProjectTask {
  id           String     @id @default(uuid())
  name         String
  description  String?    @db.Text
  phase        String?    // WBS phase / etapa
  startDate    DateTime
  endDate      DateTime
  plannedStart DateTime?
  plannedEnd   DateTime?
  percentDone  Float      @default(0) // 0..100
  status       TaskStatus @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id])
  parentId     String?
  parent       ProjectTask?  @relation("TaskHierarchy", fields: [parentId], references: [id])
  children     ProjectTask[] @relation("TaskHierarchy")

  plannedDuration  Int?
  actualStartDate  DateTime?
  actualEndDate    DateTime?
  isMilestone      Boolean        @default(false)
  color            String?
  order            Int            @default(0)
  wbsCode          String?

  dependenciesAsPredecessor TaskDependency[] @relation("DependencyPredecessor")
  dependenciesAsSuccessor   TaskDependency[] @relation("DependencySuccessor")

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("project_tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// --------------------------------------------------------
// MODULE: Treinamentos (Training Management)
// --------------------------------------------------------

model Training {
  id           String         @id @default(uuid())
  title        String
  description  String?        @db.Text
  instructor   String?
  location     String?
  startDate    DateTime
  endDate      DateTime?
  hours        Decimal        @default(0) @db.Decimal(10, 2)
  maxParticipants Int?
  status       TrainingStatus @default(SCHEDULED)
  type         TrainingType   @default(INTERNAL)
  cost         Decimal?       @db.Decimal(18, 4)
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id])
  participants TrainingParticipant[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("trainings")
}

model TrainingParticipant {
  id           String    @id @default(uuid())
  trainingId   String
  training     Training  @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id])
  attended     Boolean   @default(false)
  certified    Boolean   @default(false)
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())

  @@unique([trainingId, employeeId])
  @@map("training_participants")
}

enum TrainingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TrainingType {
  INTERNAL    // Treinamento interno
  EXTERNAL    // Treinamento externo / empresa especializada
  NR          // Normas Regulamentadoras (NR-10, NR-35, etc.)
  CERTIFICATION // Certificação profissional
  OTHER
}

// --------------------------------------------------------
// MODULE: Férias e Afastamentos (Vacation & Leave)
// --------------------------------------------------------

model VacationRequest {
  id          String          @id @default(uuid())
  employeeId  String
  employee    Employee        @relation(fields: [employeeId], references: [id])
  type        LeaveType       @default(VACATION)
  startDate   DateTime
  endDate     DateTime
  days        Int             // Number of calendar days
  status      LeaveStatus     @default(PENDING)
  reason      String?         @db.Text
  approvedBy  String?         // Name of approver
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("vacation_requests")
}

enum LeaveType {
  VACATION         // Férias
  SICK_LEAVE       // Licença Médica
  MATERNITY        // Licença Maternidade
  PATERNITY        // Licença Paternidade
  BEREAVEMENT      // Luto
  PERSONAL         // Pessoal
  ACCIDENT         // Acidente de Trabalho
  OTHER
}

enum LeaveStatus {
  PENDING   // Aguardando aprovação
  APPROVED  // Aprovado
  REJECTED  // Rejeitado
  CANCELLED // Cancelado
}

// --------------------------------------------------------
// MODULE: Compras (Purchase Orders)
// --------------------------------------------------------

model PurchaseOrder {
  id           String              @id @default(uuid())
  number       String
  status       PurchaseOrderStatus @default(DRAFT)
  supplierId   String?
  projectId    String?
  companyId    String
  totalValue   Decimal             @default(0) @db.Decimal(18, 4)
  notes        String?             @db.Text
  expectedAt   DateTime?
  receivedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  company      Company             @relation(fields: [companyId], references: [id])
  supplier     Supplier?           @relation(fields: [supplierId], references: [id])
  project      Project?            @relation(fields: [projectId], references: [id])
  items        PurchaseOrderItem[]
  costCenterId String?
  costCenter   CostCenter?         @relation("PurchaseOrderCostCenter", fields: [costCenterId], references: [id])

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  description     String        @db.Text
  unit            String
  quantity        Decimal       @db.Decimal(18, 4)
  unitPrice       Decimal       @db.Decimal(18, 4)
  totalPrice      Decimal       @db.Decimal(18, 4)
  purchaseOrderId String
  materialId      String?
  createdAt       DateTime      @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  material        Material?     @relation(fields: [materialId], references: [id])

  @@map("purchase_order_items")
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

// --------------------------------------------------------
// MODULE: RDO - Relatório Diário de Obra
// --------------------------------------------------------

model DailyReport {
  id            String              @id @default(uuid())
  date          DateTime
  projectId     String
  companyId     String
  weather       WeatherCondition    @default(SUNNY)
  temperature   Decimal?            @db.Decimal(5, 2)
  notes         String?             @db.Text
  occurrences   String?             @db.Text
  supervisorId  String?
  status        DailyReportStatus   @default(DRAFT)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  project       Project             @relation(fields: [projectId], references: [id])
  company       Company             @relation(fields: [companyId], references: [id])
  workforce     DailyReportWorker[]
  activities    DailyReportActivity[]
  photos        DailyReportPhoto[]
  equipmentLog  DailyReportEquipment[]

  reportNumber      String?
  precipitation     Decimal? @db.Decimal(5, 2)
  workingHours      Decimal  @default(8) @db.Decimal(5, 2)
  stoppageHours     Decimal  @default(0) @db.Decimal(5, 2)
  stoppageReason    String?  @db.Text
  safetyOccurrences String?  @db.Text
  qualityNotes      String?  @db.Text
  visitorsLog       String?  @db.Text
  nextDayPlan       String?  @db.Text

  @@unique([date, projectId])
  @@map("daily_reports")
}

model DailyReportWorker {
  id            String      @id @default(uuid())
  role          String
  count         Int
  reportId      String
  report        DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("daily_report_workers")
}

model DailyReportActivity {
  id            String      @id @default(uuid())
  description   String      @db.Text
  location      String?
  percentDone   Decimal     @default(0) @db.Decimal(5, 2)
  reportId      String
  report        DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("daily_report_activities")
}

enum WeatherCondition {
  SUNNY
  CLOUDY
  RAINY
  STORMY
  WINDY
}

enum DailyReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

// --------------------------------------------------------
// MODULE: Controle de Equipamentos
// --------------------------------------------------------

model Equipment {
  id            String               @id @default(uuid())
  code          String
  name          String
  type          EquipmentType
  brand         String?
  model         String?
  year          Int?
  status        EquipmentStatus      @default(AVAILABLE)
  costPerHour   Decimal?             @db.Decimal(18, 4)
  costPerDay    Decimal?             @db.Decimal(18, 4)
  isOwned       Boolean              @default(true)
  notes         String?              @db.Text

  serialNumber          String?
  manufacturer          String?
  acquisitionDate       DateTime?
  acquisitionValue      Decimal?           @db.Decimal(18, 4)
  currentValue          Decimal?           @db.Decimal(18, 4)
  depreciationRate      Decimal?           @db.Decimal(5, 2)
  depreciationMethod    DepreciationMethod @default(LINEAR)
  usefulLifeYears       Int?
  insurancePolicy       String?
  insuranceExpiry       DateTime?
  licenseNumber         String?
  fuelType              FuelType?
  avgFuelConsumption    Decimal?           @db.Decimal(10, 2)
  totalHoursWorked      Decimal            @default(0) @db.Decimal(18, 2)

  companyId     String
  company       Company              @relation(fields: [companyId], references: [id])
  usages        EquipmentUsage[]
  maintenances  EquipmentMaintenance[]
  maintenancePlan       MaintenancePlanItem[]
  documents             EquipmentDocument[]
  dailyReportEquipments DailyReportEquipment[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([code, companyId])
  @@map("equipment")
}

model EquipmentUsage {
  id           String      @id @default(uuid())
  equipmentId  String
  projectId    String
  startDate    DateTime
  endDate      DateTime?
  hours        Decimal?    @db.Decimal(10, 2)
  days         Decimal?    @db.Decimal(10, 2)
  totalCost    Decimal?    @db.Decimal(18, 4)
  operator     String?
  notes        String?     @db.Text
  equipment    Equipment   @relation(fields: [equipmentId], references: [id])
  project      Project     @relation(fields: [projectId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation("EquipmentUsageCostCenter", fields: [costCenterId], references: [id])
  createdAt    DateTime    @default(now())

  @@map("equipment_usages")
}

model EquipmentMaintenance {
  id          String          @id @default(uuid())
  equipmentId String
  type        MaintenanceType
  description String          @db.Text
  scheduledAt DateTime
  completedAt DateTime?
  cost        Decimal?        @db.Decimal(18, 4)
  provider    String?
  notes       String?         @db.Text
  equipment   Equipment       @relation(fields: [equipmentId], references: [id])
  createdAt   DateTime        @default(now())

  @@map("equipment_maintenances")
}

enum EquipmentType {
  VEHICLE
  CRANE
  EXCAVATOR
  CONCRETE_MIXER
  COMPRESSOR
  GENERATOR
  SCAFFOLD
  FORMWORK
  PUMP
  TOOL
  OTHER
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  INACTIVE
  RENTED_OUT
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INSPECTION
}

// --------------------------------------------------------
// MODULE: Task Management (Kanban)
// --------------------------------------------------------

enum WorkTaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum WorkTaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  NONE
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}


model Department {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userDepts   UserDepartment[]
  tasks       WorkTask[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([name, companyId])
  @@map("departments")
}

model UserDepartment {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  @@unique([userId, departmentId])
  @@map("user_departments")
}

model WorkTask {
  id           String           @id @default(uuid())
  title        String
  description  String?          @db.Text
  status       WorkTaskStatus   @default(TODO)
  priority     WorkTaskPriority @default(NONE)
  dueDate      DateTime?
  order        Int              @default(0)
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User             @relation("WorkTaskCreator", fields: [createdById], references: [id])
  assignments  WorkTaskAssignment[]
  comments     WorkTaskComment[]
  labels       WorkTaskLabelAssignment[]
  subtasks     WorkTaskSubtask[]
  activities   WorkTaskActivity[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  @@index([companyId, status])
  @@map("work_tasks")
}

model WorkTaskAssignment {
  id         String   @id @default(uuid())
  taskId     String
  task       WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("WorkTaskAssignee", fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())
  @@unique([taskId, userId])
  @@map("work_task_assignments")
}

model WorkTaskComment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  taskId    String
  task      WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("WorkTaskCommentAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("work_task_comments")
}

model WorkTaskLabel {
  id          String   @id @default(uuid())
  name        String
  color       String   @default("#6366f1")
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments WorkTaskLabelAssignment[]
  @@unique([name, companyId])
  @@map("work_task_labels")
}

model WorkTaskLabelAssignment {
  id      String        @id @default(uuid())
  taskId  String
  task    WorkTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  labelId String
  label   WorkTaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  @@unique([taskId, labelId])
  @@map("work_task_label_assignments")
}

model WorkTaskSubtask {
  id        String   @id @default(uuid())
  title     String
  done      Boolean  @default(false)
  order     Int      @default(0)
  taskId    String
  task      WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@map("work_task_subtasks")
}

model WorkTaskActivity {
  id        String   @id @default(uuid())
  type      String
  field     String?
  oldValue  String?
  newValue  String?
  taskId    String
  task      WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("WorkTaskActivityAuthor", fields: [userId], references: [id])
  createdAt DateTime @default(now())
  @@map("work_task_activities")
}

// --------------------------------------------------------
// MODULE: Notifications
// --------------------------------------------------------

model Notification {
  id        String   @id @default(uuid())
  type      String   // "TASK_ASSIGNED", "TASK_COMMENT", "TASK_DUE", "BULLETIN_SUBMITTED", "BULLETIN_APPROVED", "BULLETIN_REJECTED", "CONTRACT_EXPIRING", "EQUIPMENT_MAINTENANCE"
  title     String
  message   String   @db.Text
  link      String?  // URL to navigate to when clicked
  read      Boolean  @default(false)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ProjectStatusHistory {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  oldStatus String?
  newStatus String
  changedBy String
  note      String?  @db.Text
  createdAt DateTime @default(now())
  @@map("project_status_history")
}

// --------------------------------------------------------
// Feature 40: Salary History
// --------------------------------------------------------

model SalaryHistory {
  id           String   @id @default(uuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  previousCost Decimal? @db.Decimal(18, 4)
  newCost      Decimal  @db.Decimal(18, 4)
  reason       String?  @db.Text
  effectiveDate DateTime @default(now())
  createdAt    DateTime @default(now())

  @@map("salary_history")
}

// --------------------------------------------------------
// Feature 51: Announcements Board
// --------------------------------------------------------

model Announcement {
  id         String               @id @default(uuid())
  title      String
  content    String               @db.Text
  priority   AnnouncementPriority @default(NORMAL)
  isPinned   Boolean              @default(false)
  expiresAt  DateTime?
  companyId  String
  company    Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  authorId   String

model TimeEntry {
  id            String          @id @default(cuid())
  employeeId    String
  employee      Employee        @relation(fields: [employeeId], references: [id])
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id])
  projectId     String?
  project       Project?        @relation("TimeEntries", fields: [projectId], references: [id])
  date          DateTime
  clockIn       DateTime
  clockOut      DateTime?
  breakStart    DateTime?
  breakEnd      DateTime?
  totalHours    Float?
  overtimeHours Float?
  latitude      Float?

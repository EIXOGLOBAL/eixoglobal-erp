// --------------------------------------------------------
// MODULE: Audit Log
// --------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid())
  action     String // "CREATE", "UPDATE", "DELETE", "LOGIN_SUCCESS", "LOGIN_FAILED", "LOGOUT", "APPROVE", "REJECT", ...
  entity     String? // "Project", "Contract", "Bulletin", "Employee", etc. (null para eventos de sistema/auth)
  entityId   String?
  entityName String? // human-readable name
  oldData    String?  @db.Text // JSON string of old values
  newData    String?  @db.Text // JSON string of new values
  details    String?  @db.Text // texto livre adicional (motivo, contexto)
  reason     String? // razão estruturada ("validation_error", "invalid_password", ...)
  email      String? // email envolvido (mesmo se não houver user, ex: tentativa em conta inexistente)
  userId     String?
  user       User?    @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([entity, entityId])
  @@index([userId])
  @@index([action, createdAt])
  @@map("audit_logs")
}


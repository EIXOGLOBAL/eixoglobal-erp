// --------------------------------------------------------
// MODULE: Audit Log
// --------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid())
  action     String   // "CREATE", "UPDATE", "DELETE", "LOGIN", "APPROVE", "REJECT"
  entity     String   // "Project", "Contract", "Bulletin", "Employee", etc.
  entityId   String?
  entityName String?  // human-readable name
  oldData    String?  @db.Text // JSON string of old values
  newData    String?  @db.Text // JSON string of new values
  userId     String
  user       User     @relation("AuditLogUser", fields: [userId], references: [id])
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ip         String?
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ============================================================
// MODULE: Gestão de Locações
// ============================================================

enum RentalItemType {
  PROPERTY_RESIDENTIAL
  PROPERTY_COMMERCIAL
  PROPERTY_WAREHOUSE
  VEHICLE_TRUCK
  VEHICLE_VAN
  VEHICLE_CAR
  VEHICLE_MOTORCYCLE
  EQUIPMENT_CRANE
  EQUIPMENT_EXCAVATOR
  EQUIPMENT_BULLDOZER
  EQUIPMENT_MIXER
  EQUIPMENT_COMPRESSOR
  EQUIPMENT_GENERATOR
  EQUIPMENT_COMPACTOR
  EQUIPMENT_PUMP
  EQUIPMENT_WELDER
  EQUIPMENT_SCAFFOLD
  OTHER
}

enum RentalStatus {
  ACTIVE
  RETURNED
  OVERDUE
  CANCELLED
}

enum RentalBillingCycle {
  DAILY
  WEEKLY
  MONTHLY
}

model RentalItem {
  id            String         @id @default(uuid())
  name          String
  type          RentalItemType
  description   String?        @db.Text
  supplier      String?
  supplierPhone String?
  dailyRate     Decimal?       @db.Decimal(18, 4)
  weeklyRate    Decimal?       @db.Decimal(18, 4)
  monthlyRate   Decimal?       @db.Decimal(18, 4)

  companyId     String
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  rentals       Rental[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("rental_items")
}

model Rental {
  id              String             @id @default(uuid())
  itemId          String
  item            RentalItem         @relation(fields: [itemId], references: [id])

  projectId       String?
  project         Project?           @relation(fields: [projectId], references: [id])

  billingCycle    RentalBillingCycle @default(MONTHLY)
  unitRate        Decimal            @db.Decimal(18, 4)

  startDate       DateTime
  expectedEndDate DateTime?
  actualEndDate   DateTime?

  status          RentalStatus       @default(ACTIVE)
  notes           String?            @db.Text

  totalPaid       Decimal?           @default(0) @db.Decimal(18, 4)

  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])

  costCenterId    String?
  costCenter      CostCenter?        @relation("RentalCostCenter", fields: [costCenterId], references: [id])

  payments        RentalPayment[]

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("rentals")
}

model RentalPayment {
  id             String      @id @default(uuid())
  rentalId       String
  rental         Rental      @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  amount         Decimal     @db.Decimal(18, 4)
  paidDate       DateTime
  referenceMonth String?
  notes          String?     @db.Text
  projectId      String?
  project        Project?    @relation("RentalPaymentProject", fields: [projectId], references: [id])
  costCenterId   String?
  costCenter     CostCenter? @relation("RentalPaymentCostCenter", fields: [costCenterId], references: [id])
  createdAt      DateTime    @default(now())

  @@map("rental_payments")
}

// ============================================================
// MODULE: Orçamentos (Budgets)
// ============================================================

enum BudgetStatus {
  DRAFT
  APPROVED
  REJECTED
  REVISED
}

model Budget {
  id          String       @id @default(uuid())
  code        String?
  name        String
  description String?      @db.Text
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id])
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  status      BudgetStatus @default(DRAFT)
  totalValue  Decimal      @default(0) @db.Decimal(18, 4)
  items       BudgetItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("budgets")
}

model BudgetItem {
  id          String  @id @default(uuid())
  budgetId    String
  budget      Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  code        String?
  description String  @db.Text
  unit        String
  quantity    Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @db.Decimal(18, 4)
  totalPrice  Decimal @db.Decimal(18, 4)
  category    String?

  @@map("budget_items")
}

// ============================================================
// MODULE: Conciliação Bancária (Bank Reconciliation)
// ============================================================

enum BankStatementStatus {
  PENDING
  RECONCILING
  RECONCILED
  DIVERGENT
}

enum ReconciliationStatus {
  PENDING
  MATCHED
  AUTO_MATCHED
  IGNORED
  DIVERGENT
}

model BankStatement {
  id              String              @id @default(uuid())
  bankAccountId   String
  bankAccount     BankAccount         @relation(fields: [bankAccountId], references: [id])
  importedAt      DateTime            @default(now())
  period          String              // "2026-01" formato YYYY-MM
  totalCredits    Decimal             @default(0) @db.Decimal(18, 4)
  totalDebits     Decimal             @default(0) @db.Decimal(18, 4)
  status          BankStatementStatus @default(PENDING)
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  transactions    BankStatementTransaction[]
  createdBy       String
  createdAt       DateTime            @default(now())

  @@map("bank_statements")
}

model BankStatementTransaction {
  id                    String               @id @default(uuid())
  statementId           String
  statement             BankStatement        @relation(fields: [statementId], references: [id], onDelete: Cascade)
  date                  DateTime
  description           String               @db.Text
  amount                Decimal              @db.Decimal(18, 4) // positivo = crédito, negativo = débito
  balance               Decimal?             @db.Decimal(18, 4)
  type                  String               // CREDIT | DEBIT
  externalId            String?              // ID da transação no banco
  financialRecordId     String?              @unique
  financialRecord       FinancialRecord?     @relation(fields: [financialRecordId], references: [id])
  reconciliationStatus  ReconciliationStatus @default(PENDING)
  reconciliationNote    String?              @db.Text
  createdAt             DateTime             @default(now())

  @@map("bank_statement_transactions")
}

// ============================================================
// MODULE: Fornecedores Avançado (Supplier Management)

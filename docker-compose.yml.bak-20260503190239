services:
  db:
    image: postgres:17
    container_name: eixo_erp_db
    restart: unless-stopped
    environment:
      POSTGRES_USER: eixo
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: eixo_erp
    volumes:
      - pgdata:/var/lib/postgresql/data
    networks:
      - eixo_network
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U eixo -d eixo_erp
      interval: 10s
      timeout: 5s
      retries: 5
  pgbouncer:
    image: edoburu/pgbouncer:latest
    container_name: eixo_erp_pgbouncer
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    environment:
      DB_USER: eixo
      DB_PASSWORD: ${POSTGRES_PASSWORD}
      DB_HOST: db
      DB_NAME: eixo_erp
      POOL_MODE: transaction
      MAX_CLIENT_CONN: 100
      DEFAULT_POOL_SIZE: 20
      AUTH_TYPE: plain
    networks:
      - eixo_network
  minio:
    image: minio/minio:latest
    container_name: eixo_erp_minio
    restart: unless-stopped
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
    volumes:
      - minio_data:/data
    networks:
      - eixo_network
    command: server /data --console-address ":9001"
    healthcheck:
      test:
        - CMD
        - curl
        - -f
        - http://localhost:9000/minio/health/live
      interval: 15s
      timeout: 5s
      retries: 5
  minio-init:
    image: minio/mc:latest
    container_name: eixo_erp_minio_init
    restart: on-failure
    depends_on:
      minio:
        condition: service_healthy
    networks:
      - eixo_network
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
    entrypoint: |-
      sh -c "
        mc alias set local http://minio:9000 $${MINIO_ROOT_USER} $${MINIO_ROOT_PASSWORD} &&
        mc mb local/eixoglobal-erp --ignore-existing &&
        mc anonymous set download local/eixoglobal-erp/avatars &&
        mc anonymous set download local/eixoglobal-erp/logos &&
        echo '[minio-init] Bucket criado e configurado.'
      "
  erp:
    image: ghcr.io/eixoglobal/eixoglobal-erp:${IMAGE_TAG:-latest}
    pull_policy: always
    container_name: eixo_erp_app
    restart: unless-stopped
    depends_on:
      pgbouncer:
        condition: service_started
      minio:
        condition: service_healthy
    environment:
      DATABASE_URL: postgresql://eixo:${POSTGRES_PASSWORD}@pgbouncer:5432/eixo_erp?pgbouncer=true
      DIRECT_URL: postgresql://eixo:${POSTGRES_PASSWORD}@db:5432/eixo_erp
      SESSION_SECRET: ${SESSION_SECRET}
      ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY}
      NEXT_PUBLIC_APP_URL: https://erp.eixoglobal.com.br
      NEXT_PUBLIC_APP_NAME: Eixo Global ERP
      NODE_ENV: production
      PORT: 3001
      HOSTNAME: 0.0.0.0
      D4SIGN_TOKEN_API: ${D4SIGN_TOKEN_API}
      D4SIGN_CRYPT_KEY: ${D4SIGN_CRYPT_KEY}
      D4SIGN_SAFE_UUID: ${D4SIGN_SAFE_UUID}
      D4SIGN_WEBHOOK_SECRET: ${D4SIGN_WEBHOOK_SECRET}
      D4SIGN_BASE_URL: https://secure.d4sign.com.br/api/v1
      UPLOAD_MAX_SIZE: 10485760
      ADMIN_RESET_TOKEN: ${ADMIN_RESET_TOKEN:-}
      RESET_ADMIN_PASSWORD: ${RESET_ADMIN_PASSWORD:-}
      RESET_USERS: ${RESET_USERS:-}
      CRON_SECRET: ${CRON_SECRET:-}
      S3_ENDPOINT: http://minio:9000
      R2_ACCESS_KEY_ID: ${MINIO_ROOT_USER}
      R2_SECRET_ACCESS_KEY: ${MINIO_ROOT_PASSWORD}
      R2_BUCKET_NAME: eixoglobal-erp
      R2_PUBLIC_URL: ${R2_PUBLIC_URL:-}
      R2_ACCOUNT_ID: ${R2_ACCOUNT_ID:-}
      UPSTASH_REDIS_REST_URL: ${UPSTASH_REDIS_REST_URL:-}
      UPSTASH_REDIS_REST_TOKEN: ${UPSTASH_REDIS_REST_TOKEN:-}
      SENTRY_DSN: ${SENTRY_DSN:-}
      NEXT_PUBLIC_SENTRY_DSN: ${SENTRY_DSN:-}
      DIARIO_OBRA_TOKEN: ${DIARIO_OBRA_TOKEN:-}
      ALMOB_TOKEN: ${ALMOB_TOKEN:-}
    ports:
      - 127.0.0.1:3001:3001
    volumes:
      - uploads:/app/public/uploads
    networks:
      - eixo_network
      - dokploy-network
      - default
    labels:
      - traefik.docker.network=dokploy-network
      - traefik.http.routers.eixoglobalerp-eixoglobalerp-m339ov-3-web.rule=Host(`erp.eixoglobal.com.br`)
      - traefik.http.routers.eixoglobalerp-eixoglobalerp-m339ov-3-web.entrypoints=web
      - traefik.http.services.eixoglobalerp-eixoglobalerp-m339ov-3-web.loadbalancer.server.port=3001
      - traefik.http.routers.eixoglobalerp-eixoglobalerp-m339ov-3-web.service=eixoglobalerp-eixoglobalerp-m339ov-3-web
      - traefik.http.routers.eixoglobalerp-eixoglobalerp-m339ov-3-web.middlewares=redirect-to-https@file
      - traefik.http.routers.eixoglobalerp-eixoglobalerp-m339ov-3-websecure.rule=Host(`erp.eixoglobal.com.br`)
      - traefik.http.routers.eixoglobalerp-eixoglobalerp-m339ov-3-websecure.entrypoints=websecure
      - traefik.http.services.eixoglobalerp-eixoglobalerp-m339ov-3-websecure.loadbalancer.server.port=3001
      - traefik.http.routers.eixoglobalerp-eixoglobalerp-m339ov-3-websecure.service=eixoglobalerp-eixoglobalerp-m339ov-3-websecure
      - traefik.http.routers.eixoglobalerp-eixoglobalerp-m339ov-3-websecure.tls.certresolver=letsencrypt
      - traefik.enable=true
  backup:
    image: postgres:17-alpine
    container_name: eixo_erp_backup
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    environment:
      PGPASSWORD: ${POSTGRES_PASSWORD}
      R2_BACKUP_KEY_ID: ${R2_BACKUP_KEY_ID:-}
      R2_BACKUP_SECRET: ${R2_BACKUP_SECRET:-}
      R2_BACKUP_BUCKET: ${R2_BACKUP_BUCKET:-eixoglobal-erp-backups}
      R2_BACKUP_ENDPOINT: ${R2_BACKUP_ENDPOINT:-https://5336a0798a59f73e731cf3e05e404d42.r2.cloudflarestorage.com}
    volumes:
      - backups:/backups
    networks:
      - eixo_network
    command: |-
      sh -c "
        apk add --no-cache aws-cli 2>&1 | tail -1;
        echo '[backup] Servico iniciado';
        while true; do
          TS=$$(date +%Y%m%d_%H%M%S);
          FILE=/backups/backup_$$TS.dump;
          echo \"[backup] $$(date '+%Y-%m-%d %H:%M:%S') — iniciando pg_dump\";
          if pg_dump -h db -U eixo -d eixo_erp -Fc -f $$FILE; then
            SIZE=$$(du -sh $$FILE | cut -f1);
            echo \"[backup] OK local: $$FILE ($$SIZE)\";
            if [ -n \"$$R2_BACKUP_KEY_ID\" ]; then
              AWS_ACCESS_KEY_ID=$$R2_BACKUP_KEY_ID \
              AWS_SECRET_ACCESS_KEY=$$R2_BACKUP_SECRET \
              AWS_DEFAULT_REGION=auto \
              aws s3 cp $$FILE s3://$$R2_BACKUP_BUCKET/$$(basename $$FILE) \
                --endpoint-url $$R2_BACKUP_ENDPOINT 2>&1 \
                && echo \"[backup] Upload R2 OK\" \
                || echo \"[backup] AVISO: Upload R2 falhou (backup local mantido)\";
            fi;
          else
            echo \"[backup] ERRO pg_dump em $$(date)\";
            rm -f $$FILE;
          fi;
          ls -t /backups/backup_*.dump 2>/dev/null | tail -n +8 | xargs rm -f;
          COUNT=$$(ls /backups/backup_*.dump 2>/dev/null | wc -l);
          echo \"[backup] $$COUNT backup(s) locais mantidos. Proxima execucao em 24h.\";
          sleep 86400;
        done
      "
volumes:
  pgdata: null
  uploads: null
  backups: null
  minio_data: null
networks:
  eixo_network:
    driver: bridge
  dokploy-network:
    external: true
